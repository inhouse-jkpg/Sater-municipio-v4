APP_NAME=sater
SITE_URL=sater.test

DB_NAME=local
DB_USER=wp
DB_PASSWORD=wp
DB_ROOT_PASSWORD=root
# MariaDB init user (separate from root). Keep in sync with DB_USER/DB_PASSWORD.
DB_APP_USER=wp
DB_APP_PASSWORD=wp
DB_PREFIX=mun_
DB_IMAGE=mariadb:10.6
DB_PORT=3306

PMA_PORT=8080
MAILPIT_PORT=8025

WP_ENV=development
WP_HOME=https://sater.test
WP_SITEURL=https://sater.test/wp
DB_HOST=db

REDIS_HOST=redis
REDIS_PORT=6379

WP_DEBUG=true
WP_DEBUG_LOG=true
WP_DEBUG_DISPLAY=false
SCRIPT_DEBUG=true
SAVEQUERIES=true

# ACF Pro zip URL for auto-install on wordpress container start (optional override).
# MUNICIPIO_ACF_PRO_DOWNLOAD_URL=
