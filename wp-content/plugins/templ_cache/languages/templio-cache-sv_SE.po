#. Plugin Name of the plugin
#: includes/settings-page.php:6 templ_cache.php:193 templ_cache.php:194
msgid "Templ Cache"
msgstr "Templ Cache"

#. Description of the plugin
msgid ""
"Helper plugin for the Templ server cache. Purges the cache automatically "
"when content changes. Also includes a manual purge button."
msgstr ""
"Hjälpplugin för Templs server-cache. Rensar cache automatiskt när innehållet "
"på sidan ändras. Inkluderar också en knapp för manuell rensning."

#. Author of the plugin
#: templ_cache.php:167
msgid "Templ"
msgstr "Templ"

#. Author URI of the plugin
msgid "https://templ.io/"
msgstr "https://templ.io/"

#: includes/settings-page.php:10
msgid ""
"The Templ Cache plugin is activated automatically when needed by the server. "
"If enabled, you may see the the need to manually purge the cache at times. "
"If there are any questions, please contact Templ support."
msgstr ""
"Detta plugin aktiveras automatiskt av servern vid behov. Om det är aktiverat "
"kan du ibland behöva rensa cache manuellt. Om du har några frågor, tveka "
"inte på att höra av dig till Templs support."

#: includes/settings-page.php:17
msgid "Purge Automatically"
msgstr "Automatisk rensning"

#: includes/settings-page.php:21
msgid "Automatically remove all cached pages when content changes"
msgstr "Rensa automatiskt alla cachade sidor när innehåll ändras"

#: includes/settings-page.php:30
msgid "Purge Cache"
msgstr "Rensa cache"

#: templ_cache.php:133
msgid "Cache purged."
msgstr "Cache rensad."

#: templ_cache.php:138
msgid "Cache could not be purged. "
msgstr "Cache kunde inte rensas. "

#: templ_cache.php:175
msgid "Purge cache"
msgstr "Rensa cache"

