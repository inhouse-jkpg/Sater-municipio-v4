# Environment & secrets
.env
auth.json
.devcontainer/.env

# Editor & dev tooling
/.vscode/
.DS_Store

# Documentation
/docs/

# Configuration
/config/*

# WordPress core
/wp/

# WordPress content
/wp-content/uploads/
/wp-content/upgrade/
/wp-content/uploads_backup/

# WordPress mu-plugins (track custom code only; Composer installs the rest)
/wp-content/mu-plugins/*
!/wp-content/mu-plugins/sater-*/
!/wp-content/mu-plugins/local_*/
!/wp-content/mu-plugins/loader.php
!/wp-content/mu-plugins/custom-events-order/
!/wp-content/mu-plugins/modularity-translations/

# WordPress themes (Composer-managed; built via build.php)
/wp-content/themes/*
!/wp-content/themes/index.php

# WordPress plugins (track local_* and modularity only)
/wp-content/plugins/advanced-custom-fields-pro/
/wp-content/plugins/*
!/wp-content/plugins/local_*/
!/wp-content/plugins/modularity/
/wp-content/plugins/modularity/node_modules/

# WordPress runtime & cache
/wp-content/litespeed/
/wp-content/.defender-security-quarantine/

# Dependencies
/vendor/
**/node_modules/

# Local services & infrastructure
mailpit/
nginx/ssl/
db/*.sql

# Web server
.htaccess
!/.devcontainer/config/.htaccess

# Logs
*.log
